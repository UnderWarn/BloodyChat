<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Команда проекта</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #0f0f17;
      color: #e0e0ff;
      margin: 0;
      height: 100vh;
      display: flex;
      flex-direction: column;
    }
    header {
      background: #1a1a2e;
      padding: 12px 16px;
      border-bottom: 1px solid #333;
      text-align: center;
      font-weight: bold;
    }
    #auth-screen, #chat-screen {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }
    #chat-screen {
      display: none;
    }
    .container {
      width: 100%;
      max-width: 580px;
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    #messages {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      background: #141422;
      border-radius: 10px;
      margin-bottom: 12px;
    }
    .message {
      margin: 10px 0;
      padding: 10px 14px;
      border-radius: 18px;
      max-width: 80%;
      word-wrap: break-word;
      position: relative;
    }
    .message.sent {
      background: #006aff;
      color: white;
      align-self: flex-end;
      margin-left: auto;
    }
    .message.received {
      background: #2a2a3a;
      align-self: flex-start;
    }
    .message .sender {
      font-size: 0.78em;
      opacity: 0.7;
      margin-bottom: 4px;
      display: block;
    }
    form {
      display: flex;
      gap: 8px;
    }
    #messageInput {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid #444;
      border-radius: 24px;
      background: #1e1e2e;
      color: white;
      font-size: 16px;
      outline: none;
    }
    button {
      padding: 0 20px;
      background: #006aff;
      color: white;
      border: none;
      border-radius: 24px;
      font-weight: bold;
      cursor: pointer;
    }
    button:hover {
      background: #0055cc;
    }
    .auth-box {
      background: #1a1a2e;
      padding: 32px;
      border-radius: 16px;
      width: 100%;
      max-width: 420px;
      text-align: center;
    }
    .auth-box h2 {
      margin-top: 0;
      color: #a0a0ff;
    }
    input[type="text"], input[type="password"], input[type="email"] {
      width: 100%;
      padding: 12px;
      margin: 10px 0;
      border: 1px solid #444;
      border-radius: 8px;
      background: #0f0f17;
      color: white;
      font-size: 16px;
    }
    .error {
      color: #ff6b6b;
      font-size: 0.9em;
      margin-top: 8px;
    }
    #toggle-auth {
      color: #4dabff;
      cursor: pointer;
      text-decoration: underline;
      margin-top: 16px;
      display: inline-block;
    }
  </style>
</head>
<body>

  <!-- Экран авторизации / регистрации -->
  <div id="auth-screen">
    <div class="auth-box">
      <h2 id="form-title">Вход / Регистрация</h2>
      
      <input type="text" id="username" placeholder="Имя (ник)" autocomplete="off" />
      <input type="email" id="email" placeholder="Email (просто для вида)" autocomplete="off" />
      <input type="password" id="password" placeholder="Пароль" autocomplete="new-password" />

      <button id="submit-auth">Зарегистрироваться</button>
      <div class="error" id="error-msg"></div>

      <div id="toggle-auth">Уже есть аккаунт? Войти</div>
    </div>
  </div>

  <!-- Экран чата -->
  <div id="chat-screen">
    <header>Команда Проекта</header>
    
    <div class="container">
      <div id="messages"></div>

      <form id="messageForm">
        <input type="text" id="messageInput" placeholder="Напиши сообщение... (max 700 символов)" maxlength="700" autocomplete="off" />
        <button type="submit">→</button>
      </form>
    </div>
  </div>

  <script>
    const authScreen = document.getElementById('auth-screen');
    const chatScreen  = document.getElementById('chat-screen');
    const myNicknameEl = document.getElementById('my-nickname');
    const messagesDiv  = document.getElementById('messages');
    const form         = document.getElementById('messageForm');
    const input        = document.getElementById('messageInput');

    const usernameInput = document.getElementById('username');
    const emailInput    = document.getElementById('email');
    const passInput     = document.getElementById('password');
    const submitBtn     = document.getElementById('submit-auth');
    const errorMsg      = document.getElementById('error-msg');
    const toggleLink    = document.getElementById('toggle-auth');
    const formTitle     = document.getElementById('form-title');

    let currentUser = null;
    let isLoginMode = false;

    // Показать/скрыть экраны
    function showChat() {
      authScreen.style.display = 'none';
      chatScreen.style.display = 'flex';
    }

    function showAuth() {
      authScreen.style.display = 'flex';
      chatScreen.style.display = 'none';
    }

    // Загрузка текущего пользователя
    function loadUser() {
      const data = localStorage.getItem('simpleChatUser');
      if (data) {
        currentUser = JSON.parse(data);
        myNicknameEl.textContent = currentUser.username;
        showChat();
        loadMessages();
      }
    }

    // Сохранение сообщений (один общий массив для простоты)
    function saveMessage(text) {
      let msgs = JSON.parse(localStorage.getItem('simpleChatMessages') || '[]');
      msgs.push({
        sender: currentUser.username,
        text: text,
        time: new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})
      });
      localStorage.setItem('simpleChatMessages', JSON.stringify(msgs));
      renderMessages();
    }

    function loadMessages() {
      const msgs = JSON.parse(localStorage.getItem('simpleChatMessages') || '[]');
      renderMessages(msgs);
    }

    function renderMessages() {
      messagesDiv.innerHTML = '';
      const msgs = JSON.parse(localStorage.getItem('simpleChatMessages') || '[]');

      msgs.forEach(m => {
        const div = document.createElement('div');
        div.className = `message ${m.sender === currentUser.username ? 'sent' : 'received'}`;
        
        const senderSpan = document.createElement('span');
        senderSpan.className = 'sender';
        senderSpan.textContent = m.sender;

        div.appendChild(senderSpan);
        div.appendChild(document.createTextNode(m.text));
        
        // время можно добавить, если хочется
        // const time = document.createElement('small');
        // time.textContent = m.time;
        // div.appendChild(time);

        messagesDiv.appendChild(div);
      });

      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }

    // Регистрация / Вход
    submitBtn.onclick = () => {
      const username = usernameInput.value.trim();
      const email    = emailInput.value.trim();
      const pass     = passInput.value.trim();

      errorMsg.textContent = '';

      if (!username || username.length < 2) {
        errorMsg.textContent = 'Имя должно быть минимум 2 символа';
        return;
      }
      if (!email.includes('@')) {
        errorMsg.textContent = 'Похоже, это не email';
        return;
      }
      if (!pass || pass.length < 4) {
        errorMsg.textContent = 'Пароль минимум 4 символа';
        return;
      }

      const users = JSON.parse(localStorage.getItem('simpleChatUsers') || '{}');

      if (!isLoginMode) {
        // Регистрация
        if (users[username]) {
          errorMsg.textContent = 'Такое имя уже занято';
          return;
        }
        users[username] = { username, email, password: pass };
        localStorage.setItem('simpleChatUsers', JSON.stringify(users));

        currentUser = { username, email };
        localStorage.setItem('simpleChatUser', JSON.stringify(currentUser));
        showChat();
        loadMessages();
      } else {
        // Вход
        if (!users[username] || users[username].password !== pass) {
          errorMsg.textContent = 'Неправильное имя или пароль';
          return;
        }
        currentUser = { username, email: users[username].email };
        localStorage.setItem('simpleChatUser', JSON.stringify(currentUser));
        showChat();
        loadMessages();
      }
    };

    // Переключение режимов Вход / Регистрация
    toggleLink.onclick = () => {
      isLoginMode = !isLoginMode;
      if (isLoginMode) {
        formTitle.textContent = 'Вход';
        submitBtn.textContent = 'Войти';
        toggleLink.textContent = 'Нет аккаунта? Зарегистрироваться';
      } else {
        formTitle.textContent = 'Регистрация';
        submitBtn.textContent = 'Зарегистрироваться';
        toggleLink.textContent = 'Уже есть аккаунт? Войти';
      }
      errorMsg.textContent = '';
    };

    // Отправка сообщения
    form.onsubmit = e => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text) return;

      saveMessage(text);
      input.value = '';
    };

    // Запуск
    loadUser();
  </script>
</body>
</html>
